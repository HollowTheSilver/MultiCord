{
  "version": "1.0.0",
  "author": "Discord Cloud Platform",
  "category": "builtin",
  "difficulty": "advanced",
  "customizable_flags": [
    "auto_moderation",
    "max_warnings",
    "timeout_duration",
    "log_channel",
    "custom_commands",
    "webhook_notifications"
  ],
  "name": "Music Bot",
  "description": "Music streaming bot with playlists, queues, and lyrics",
  "recommended_database": "firestore",
  "default_flags": {
    "base_commands": true,
    "music_streaming": true,
    "playlist_support": true,
    "queue_management": true,
    "lyrics_enabled": true,
    "volume_control": true,
    "limits": {
      "queue_limit": 50,
      "playlist_limit": 20,
      "max_song_duration": 3600
    }
  }
}