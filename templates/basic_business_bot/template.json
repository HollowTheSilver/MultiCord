{
  "display_name": "Basic Business Bot Template",
  "description": "A professional Discord bot template with common business bot features. Provides technical convenience features without business logic coupling.",
  "version": "1.0.0",
  "author": "MultiCord Platform",
  "template_type": "builtin",
  
  "main_file": "bot.py",
  
  "features": [
    "branding_enhancement",
    "monitoring_service",
    "logging_enhancement",
    "permission_management"
  ],
  
  "requirements": [
    {
      "type": "environment_variable",
      "name": "DISCORD_TOKEN",
      "required": true,
      "description": "Discord bot token for authentication"
    },
    {
      "type": "environment_variable", 
      "name": "BOT_NAME",
      "required": false,
      "description": "Custom bot display name",
      "default": "MultiCord Bot"
    },
    {
      "type": "environment_variable",
      "name": "COMMAND_PREFIX", 
      "required": false,
      "description": "Bot command prefix",
      "default": "!"
    },
    {
      "type": "feature",
      "name": "branding_enhancement",
      "required": false,
      "description": "Enhanced branding and visual customization"
    }
  ],
  
  "environment": {
    "PYTHONIOENCODING": "utf-8",
    "BOT_TEMPLATE": "basic_business_bot",
    "TEMPLATE_VERSION": "1.0.0"
  },
  
  "commands": [
    "help",
    "info", 
    "status",
    "ping"
  ],
  
  "technical_features": {
    "auto_help_command": true,
    "error_handling": true,
    "activity_status": true,
    "command_logging": true,
    "health_endpoints": true
  },
  
  "configuration_schema": {
    "embed_colors": {
      "primary": "#3498db",
      "success": "#2ecc71", 
      "warning": "#f39c12",
      "error": "#e74c3c"
    },
    "activity_status": {
      "type": "watching",
      "text": "for commands | {{COMMAND_PREFIX}}help"
    },
    "features": {
      "welcome_messages": false,
      "moderation_tools": false,
      "economy_system": false,
      "custom_commands": true
    }
  }
}